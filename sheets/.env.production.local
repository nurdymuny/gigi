VITE_GIGI_BASE_URL=https://gigi-stream.fly.dev
# Empty = same-origin relative paths. Sheets is hosted on
# www.davisgeometric.com (or apex); auth API lives at the same origin
# under /api/auth/*. An absolute URL would force a cross-subdomain
# request, which trips CORS preflight + the apex↔www canonicalization
# 307 redirect (preflight forbids redirects).
VITE_AUTH_BASE_URL=
