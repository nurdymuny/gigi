    { "name": "Query", "description": "Point queries, filtered queries, counting" },
    { "name": "PRISM", "description": "PRISM-compatible REST endpoints" },
    { "name": "Joins", "description": "Pullback joins between bundles" },
    { "name": "Analytics", "description": "Curvature, spectral, stats, explain" },
    { "name": "Schema", "description": "Schema evolution (add fields, indexes)" },
    { "name": "Import/Export", "description": "Bulk data import/export" },
