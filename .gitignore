/target

# Runtime data
/gigi_data/

# Local scratch: pre-encryption backups, ad-hoc dumps, anything sensitive.
# Never push this directory.
/_local/

# Build artifacts
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
*.log
*.out
*.pdf
*.tex
# …but always commit theory papers and the patent draft — these are
# load-bearing source, not scratch.
!theory/**/*.tex
!GIGI_Provisional_Patent.tex

# Test output
test_output*.txt
# Build/compile logs that aren't .log extension
*compile_log.txt
pdflatex_output.txt
check_errors*.txt

# Local images / scratch
*.jpg
*.png

# Python test scripts
gigi_math_tests*.py
# Python build artifacts
__pycache__/
*.pyc
*.egg-info/
sdk/python/dist/
sdk/python/build/
sdk/notebook/dist/
sdk/notebook/build/
.pytest_cache/

# Vite cache
.vite/

# Node modules
node_modules/
docs/node_modules/
playground/node_modules/
site/node_modules/

# Claude Code harness session state
.claude/

# Cargo alt target dirs (CARGO_TARGET_DIR overrides)
target_test/
target-test/

# One-off backups
src/sheaf_old_backup.bak
